# 모든 숨김 파일 및 폴더 무시 (.agents, .venv, .idea 등 포함)
.*
# 단, .gitignore 자체는 예외로 두어 버전 관리 대상에 포함
!.gitignore
!.env.example

# 파이썬(Python)
__pycache__/
*.py[cod]
*$py.class

# 가상환경 (일반 폴더명인 경우)
venv/
env/

# 데이터 파일 (데이터 분석 시 주로 사용되는 파일 확장자 및 폴더)
*.csv
*.tsv
*.dat
*.out
*.log
*.parquet
*.h5
*.hdf5
*.sqlite
*.db
data/
datasets/
raw_data/
processed_data/

# OS 시스템 파일
Thumbs.db

# 빌드, 배포, 테스트 로그
build/
dist/
*.egg-info/
htmlcov/
!.gitkeep